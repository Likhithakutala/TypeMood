{
  "manifest_version": 3,
  "name": "TypeMood",
  "version": "0.1.0",
  "description": "Detects emotional state from keystroke dynamics",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TypeMood"
  }
}
